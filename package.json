{
  "name": "it-move",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm --prefix frontend install && npm --prefix backend install",
    "frontend": "npm --prefix frontend run dev",
    "backend": "concurrently -k --names API,TTS --prefix-colors blue,magenta \"npm run backend:api\" \"npm run tts:service\"",
    "backend:api": "npm --prefix backend start",
    "migrate": "npm --prefix backend run migrate",
    "build": "npm --prefix frontend run build",
    "preview": "npm --prefix frontend run preview",
    "lint": "npm --prefix frontend run lint",
    "encode:hls": "npm --prefix backend run encode:hls",
    "tts:setup": "npm --prefix backend run tts:setup",
    "tts:service": "npm --prefix backend run tts:service",
    "import:kkphim": "npm --prefix backend run import:kkphim",
    "seed:views": "npm --prefix backend run seed:views"
  },
  "dependencies": {
    "swiper": "^11.2.10"
  },
  "version": "1.0.0",
  "description": "IT Move là website xem phim trực tuyến dùng React + Vite cho frontend, Node.js + Express cho backend và MySQL/MariaDB cho database.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TanTran161024/it-move.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/TanTran161024/it-move/issues"
  },
  "homepage": "https://github.com/TanTran161024/it-move#readme"
}
